# ============================================================
# Urban Pulse - Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Snowflake ---
SNOWFLAKE_ACCOUNT=your_account.snowflakecomputing.com
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=URBAN_PULSE
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=SYSADMIN

# --- PostgreSQL (Operational DB) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=urban_pulse_ops
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- AI / LLM ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Weather API ---
OPENWEATHER_API_KEY=your_openweather_api_key_here
CITY_LAT=19.0760
CITY_LON=72.8777
CITY_NAME=Mumbai

# --- Data Generator Settings ---
UBER_EVENTS_PER_SECOND=100
ZOMATO_EVENTS_PER_SECOND=80
SIMULATION_CITY=Mumbai
NUM_ZONES=12
NUM_DRIVERS=500
NUM_RESTAURANTS=200

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your-super-secret-jwt-key-change-this
API_DEBUG=True

# --- Airflow ---
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost/airflow

# --- Spark ---
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/urban_pulse.log
